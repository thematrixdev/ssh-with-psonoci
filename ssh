#!/usr/bin/env python3
"""psono-ssh — SSH wrapper that loads the matching Psono key per host.

Lookup:  Psono secret title  → SSH Host alias
         Psono secret notes  → SSH HostName (actual IP / hostname)

Matched: starts a single-key temp agent, overrides IdentityAgent
No match: passes through to /usr/bin/ssh unchanged
"""

import json
import os
import signal
import subprocess
import sys
from pathlib import Path

SSH_BIN    = "/usr/bin/ssh"
CONFIG     = Path("~/.config/psono-agent/config.json").expanduser()

# SSH options that consume the next argument
OPTS_WITH_ARG = set("bcDeFIiJLlmopQRSwW")


def find_host_arg(args: list[str]) -> tuple[int | None, str, str | None]:
    """Return (index, user_prefix, host) of the destination argument."""
    skip = False
    for i, arg in enumerate(args):
        if skip:
            skip = False
            continue
        if arg == "--":
            break
        if arg.startswith("-") and len(arg) == 2 and arg[1] in OPTS_WITH_ARG:
            skip = True
            continue
        if arg.startswith("-"):
            continue
        if "@" in arg:
            user, host = arg.split("@", 1)
            return i, user + "@", host
        return i, "", arg
    return None, "", None


def find_secret(accounts: list, host: str) -> tuple[str, str, str | None] | None:
    """Return (psono_cfg, secret_id, hostname) where title matches host."""
    for account in accounts:
        psono_cfg = str(Path(account["psono_config"]).expanduser())
        try:
            r = subprocess.run(
                ["psonoci", "-c", psono_cfg, "api-key", "secrets"],
                capture_output=True, text=True, check=True,
            )
            secrets = json.loads(r.stdout)
        except Exception:
            continue
        for secret_id, data in secrets.items():
            if data.get("title") == host:
                hostname = (data.get("notes") or "").strip() or None
                return psono_cfg, secret_id, hostname
    return None


def start_agent(sock_path: str) -> int | None:
    """Start ssh-agent on sock_path, return its PID or None."""
    r = subprocess.run(
        ["ssh-agent", "-a", sock_path],
        capture_output=True, text=True,
    )
    for line in r.stdout.splitlines():
        if "SSH_AGENT_PID=" in line:
            return int(line.split("SSH_AGENT_PID=")[1].split(";")[0])
    return None


def main() -> int:
    args = list(sys.argv[1:])

    # Load config; if unavailable just exec real ssh
    try:
        with open(CONFIG) as f:
            cfg = json.load(f)
    except Exception:
        os.execv(SSH_BIN, [SSH_BIN] + args)

    idx, user_prefix, host = find_host_arg(args)
    match = find_secret(cfg["accounts"], host) if host else None

    sock_path = f"/tmp/psono-ssh-{os.getpid()}.sock"
    agent_pid = None

    if match:
        psono_cfg, secret_id, hostname = match

        # Replace Host alias with actual HostName from notes
        if hostname and idx is not None:
            args[idx] = user_prefix + hostname

        agent_pid = start_agent(sock_path)
        if agent_pid:
            subprocess.run(
                ["psonoci", "-c", psono_cfg, "ssh", "add", secret_id,
                 "--ssh-auth-sock-path", sock_path],
                capture_output=True,
            )

    # Build final ssh command
    if agent_pid:
        # Override any IdentityAgent in ~/.ssh/config with our single-key agent
        final_args = [SSH_BIN, "-o", f"IdentityAgent={sock_path}"] + args
    else:
        final_args = [SSH_BIN] + args

    try:
        return subprocess.run(final_args).returncode
    finally:
        if agent_pid:
            try:
                os.kill(agent_pid, signal.SIGTERM)
            except ProcessLookupError:
                pass
            Path(sock_path).unlink(missing_ok=True)


if __name__ == "__main__":
    sys.exit(main())
