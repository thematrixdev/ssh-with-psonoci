#!/usr/bin/env bash
# psono-ssh — SSH wrapper that loads the matching Psono key per host
#
# Lookup:  Psono secret title  → SSH Host alias
#          Psono secret notes  → SSH config directives (HostName, Port, User, etc.)
#
# Matched: starts a single-key temp agent, passes notes as -o options
# No match: passes through to /usr/bin/ssh unchanged

SSH_BIN="/usr/bin/ssh"
CONFIG="$HOME/.config/psono-agent/config.json"

# SSH options that consume the next argument
OPTS_WITH_ARG="bcDeFIiJLlmopQRSwW"

expand_path() { echo "${1/#\~/$HOME}"; }

# Sets HOST_ALIAS from "$@"
find_host_alias() {
    HOST_ALIAS=""
    local skip_next=0

    for arg in "$@"; do
        if [[ $skip_next -eq 1 ]]; then
            skip_next=0
            continue
        fi
        [[ "$arg" == "--" ]] && break
        if [[ "$arg" =~ ^-[${OPTS_WITH_ARG}]$ ]]; then
            skip_next=1
            continue
        fi
        if [[ "$arg" =~ ^- ]]; then
            continue
        fi
        # First non-option argument is the destination; strip user@ prefix
        if [[ "$arg" == *@* ]]; then
            HOST_ALIAS="${arg##*@}"
        else
            HOST_ALIAS="$arg"
        fi
        return
    done
}

# Sets FOUND_CFG, FOUND_ID, FOUND_NOTES; returns 0 on match
find_secret() {
    local host="$1"
    local num_accounts
    num_accounts=$(jq '.accounts | length' "$CONFIG")

    for i in $(seq 0 $((num_accounts - 1))); do
        local psono_cfg secrets secret_id
        psono_cfg=$(expand_path "$(jq -r ".accounts[$i].psono_config" "$CONFIG")")

        secrets=$(psonoci -c "$psono_cfg" api-key secrets 2>/dev/null) || continue

        secret_id=$(echo "$secrets" | jq -r --arg h "$host" \
            'to_entries[] | select(.value.title == $h) | .key' | head -1)

        if [[ -n "$secret_id" ]]; then
            FOUND_CFG="$psono_cfg"
            FOUND_ID="$secret_id"
            FOUND_NOTES=$(echo "$secrets" | jq -r --arg id "$secret_id" \
                '.[$id].notes // ""')
            return 0
        fi
    done
    return 1
}

# Parses notes (ssh_config format) into SSH_OPTS array of -o arguments
parse_notes() {
    local notes="$1"
    SSH_OPTS=()
    [[ -z "$notes" ]] && return

    while IFS= read -r line; do
        # Trim leading/trailing whitespace
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        # Skip empty lines, comments, and lines without a key-value pair
        [[ -z "$line" || "$line" == \#* || "$line" != *" "* ]] && continue
        # Extract key (first word) and value (rest)
        local key="${line%% *}"
        local value="${line#* }"
        SSH_OPTS+=(-o "$key=$value")
    done <<< "$notes"
}

main() {
    [[ ! -f "$CONFIG" ]] && exec "$SSH_BIN" "$@"

    find_host_alias "$@"
    [[ -z "$HOST_ALIAS" ]] && exec "$SSH_BIN" "$@"

    local sock_path="/tmp/psono-ssh-$$.sock"
    local agent_pid=""
    local FOUND_CFG="" FOUND_ID="" FOUND_NOTES=""

    if find_secret "$HOST_ALIAS"; then
        parse_notes "$FOUND_NOTES"

        # Start temp agent with just this one key
        eval "$(ssh-agent -a "$sock_path" 2>/dev/null)" >/dev/null
        agent_pid="$SSH_AGENT_PID"

        if [[ -n "$agent_pid" ]]; then
            psonoci -c "$FOUND_CFG" ssh add "$FOUND_ID" \
                --ssh-auth-sock-path "$sock_path" >/dev/null 2>&1 || true
        fi
    fi

    local ret=0
    if [[ -n "$agent_pid" ]]; then
        # Notes options first, then user args; direct flags (-p, -l) override -o
        "$SSH_BIN" -o "IdentityAgent=$sock_path" "${SSH_OPTS[@]}" "$@"
        ret=$?
        kill "$agent_pid" 2>/dev/null || true
        rm -f "$sock_path"
    else
        "$SSH_BIN" "$@"
        ret=$?
    fi

    return $ret
}

main "$@"
