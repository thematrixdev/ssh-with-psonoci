#!/usr/bin/env bash
# psono-ssh — SSH wrapper that loads the matching Psono key per host
#
# Lookup:  Psono secret title  → SSH Host alias
#          Psono secret notes  → SSH config directives (HostName, Port, User, etc.)
#
# Matched: uses the persistent Psono agent if available, otherwise
#          starts a single-key temp agent; passes notes as -o options
# No match: passes through to /usr/bin/ssh unchanged

SSH_BIN="/usr/bin/ssh"
CONFIG="$HOME/.config/psono-agent/config.json"
CACHE_DIR="$HOME/.cache/psono-agent"
CACHE_FILE="$CACHE_DIR/secrets.json"
DAEMON_SOCK=$(cat "$CACHE_DIR/socket_path" 2>/dev/null || true)
DAEMON_PID_FILE="$CACHE_DIR/daemon.pid"
CACHE_HIT=0

# SSH options that consume the next argument
OPTS_WITH_ARG="bcDeFIiJLlmopQRSwW"

expand_path() { echo "${1/#\~/$HOME}"; }

# Sets HOST_ALIAS from "$@"
find_host_alias() {
    HOST_ALIAS=""
    local skip_next=0
    local after_dashdash=0

    for arg in "$@"; do
        if [[ $skip_next -eq 1 ]]; then
            skip_next=0
            continue
        fi
        if [[ "$arg" == "--" ]]; then
            after_dashdash=1
            continue
        fi
        if [[ $after_dashdash -eq 0 ]]; then
            if [[ "$arg" =~ ^-[${OPTS_WITH_ARG}]$ ]]; then
                skip_next=1
                continue
            fi
            if [[ "$arg" =~ ^- ]]; then
                continue
            fi
        fi
        # First non-option argument is the destination; strip user@ prefix
        if [[ "$arg" == *@* ]]; then
            HOST_ALIAS="${arg##*@}"
        else
            HOST_ALIAS="$arg"
        fi
        return
    done
}

# Sets FOUND_CFG, FOUND_ID, FOUND_NOTES; returns 0 on match
# Tries local cache first, falls back to API
find_secret() {
    local host="$1"

    # Try cache (instant)
    if [[ -f "$CACHE_FILE" ]]; then
        local entry
        entry=$(jq -r --arg h "$host" '.[$h] // empty' "$CACHE_FILE" 2>/dev/null)
        if [[ -n "$entry" ]]; then
            FOUND_CFG=$(echo "$entry" | jq -r '.psono_config')
            FOUND_CFG="${FOUND_CFG/#\~/$HOME}"
            FOUND_ID=$(echo "$entry" | jq -r '.secret_id')
            FOUND_NOTES=$(echo "$entry" | jq -r '.notes')
            CACHE_HIT=1
            return 0
        fi
    fi

    # Cache miss — call API
    local num_accounts
    num_accounts=$(jq '.accounts | length' "$CONFIG")

    for i in $(seq 0 $((num_accounts - 1))); do
        local psono_cfg secrets secret_id
        psono_cfg=$(expand_path "$(jq -r ".accounts[$i].psono_config" "$CONFIG")")

        secrets=$(psonoci -c "$psono_cfg" api-key secrets 2>/dev/null) || continue

        secret_id=$(echo "$secrets" | jq -r --arg h "$host" \
            'to_entries[] | select(.value.title == $h) | .key' | head -1)

        if [[ -n "$secret_id" ]]; then
            FOUND_CFG="$psono_cfg"
            FOUND_ID="$secret_id"
            FOUND_NOTES=$(echo "$secrets" | jq -r --arg id "$secret_id" \
                '.[$id].notes // ""')
            return 0
        fi
    done
    return 1
}

# Parses notes (ssh_config format) into SSH_OPTS array of -o arguments
parse_notes() {
    local notes="$1"
    SSH_OPTS=()
    [[ -z "$notes" ]] && return

    while IFS= read -r line; do
        # Trim leading/trailing whitespace
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        # Skip empty lines, comments, and lines without a key-value pair
        [[ -z "$line" || "$line" == \#* || "$line" != *" "* ]] && continue
        # Extract key (first word) and value (rest)
        local key="${line%% *}"
        local value="${line#* }"
        SSH_OPTS+=(-o "$key=$value")
    done <<< "$notes"
}

main() {
    [[ ! -f "$CONFIG" ]] && exec "$SSH_BIN" "$@"

    # Pass through version/query operations immediately
    for arg in "$@"; do
        [[ "$arg" == "-V" || "$arg" == "-Q" ]] && exec "$SSH_BIN" "$@"
    done

    find_host_alias "$@"
    [[ -z "$HOST_ALIAS" ]] && exec "$SSH_BIN" "$@"

    local FOUND_CFG="" FOUND_ID="" FOUND_NOTES=""

    if ! find_secret "$HOST_ALIAS"; then
        exec "$SSH_BIN" "$@"
    fi

    parse_notes "$FOUND_NOTES"

    # Resolve cached public key (written by psono-ssh-agent daemon)
    local cached_pubkey="$CACHE_DIR/$FOUND_ID.pub"
    local key_opts=()
    if [[ -n "$DAEMON_SOCK" && -S "$DAEMON_SOCK" && -s "$cached_pubkey" ]]; then
        key_opts=(-o "IdentitiesOnly=yes" -o "IdentityFile=$cached_pubkey")
    fi

    # For config queries (ssh -G), inject options and return immediately
    for arg in "$@"; do
        if [[ "$arg" == "-G" ]]; then
            exec "$SSH_BIN" "${key_opts[@]}" "${SSH_OPTS[@]}" "$@"
        fi
    done

    # Prepare agent for actual connections
    local sock_path=""
    local agent_pid=""

    if [[ $CACHE_HIT -eq 1 && -n "$DAEMON_SOCK" && -S "$DAEMON_SOCK" ]]; then
        # Cache hit + persistent Psono agent is running — key is loaded
        sock_path="$DAEMON_SOCK"
    else
        # Cache miss or no daemon; use a temp single-key agent
        sock_path="/tmp/psono-ssh-$$.sock"
        key_opts=()  # not needed — temp agent has only one key
        eval "$(ssh-agent -a "$sock_path" 2>/dev/null)" >/dev/null
        agent_pid="$SSH_AGENT_PID"

        if [[ -n "$agent_pid" ]]; then
            if ! psonoci -c "$FOUND_CFG" ssh add "$FOUND_ID" \
                --ssh-auth-sock-path "$sock_path" >/dev/null 2>&1; then
                # Fallback: fetch key, ensure trailing newline, load with ssh-add
                local tmpkey
                tmpkey=$(mktemp "/tmp/psono-ssh-key-$$.XXXXXX")
                if psonoci -c "$FOUND_CFG" secret get "$FOUND_ID" ssh_key_private \
                    > "$tmpkey" 2>/dev/null && [[ -s "$tmpkey" ]]; then
                    [[ "$(tail -c1 "$tmpkey" | xxd -p)" == "0a" ]] || printf '\n' >> "$tmpkey"
                    chmod 600 "$tmpkey"
                    SSH_AUTH_SOCK="$sock_path" ssh-add "$tmpkey" >/dev/null 2>&1 || true
                fi
                rm -f "$tmpkey"
            fi
        fi

        # Signal daemon to reload so future calls use cache
        if [[ $CACHE_HIT -eq 0 && -f "$DAEMON_PID_FILE" ]]; then
            local dpid
            dpid=$(cat "$DAEMON_PID_FILE" 2>/dev/null)
            if [[ -n "$dpid" ]] && kill -0 "$dpid" 2>/dev/null; then
                kill -HUP "$dpid" 2>/dev/null || true
            fi
        fi
    fi

    # Notes options first, then user args; direct flags (-p, -l) override -o
    "$SSH_BIN" -o "IdentityAgent=$sock_path" "${key_opts[@]}" "${SSH_OPTS[@]}" "$@"
    local ret=$?
    if [[ -n "$agent_pid" ]]; then
        kill "$agent_pid" 2>/dev/null || true
        rm -f "$sock_path"
    fi

    return $ret
}

main "$@"
